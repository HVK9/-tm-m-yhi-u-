// Cấu hình
int  interval         = 100;   // ms
int  randomVariance   = 20;    // ± ms
int  maxClicks        = 0;
int  currentHotkey    = VK_F2;
int  clickType        = 0;     // 0=Left, 1=Right, 2=Double

// Thống kê
volatile LONG totalClicks = 0;
volatile LONG clicksInSecond = 0;
float currentCPS      = 0.0f;

// Fixed position
int fixedX = 0, fixedY = 0;

// Event cho thread
HANDLE hClickEvent   = NULL;
HANDLE hStopEvent    = NULL;

// ============================================================
//   HELPER: Lấy số ngẫu nhiên trong khoảng [lo, hi]
// ============================================================
int RandRange(int lo, int hi) {
    if (lo >= hi) return lo;
    return lo + (rand() % (hi - lo + 1));
}

// ============================================================
//   THREAD: THỰC HIỆN CLICK
// ============================================================
DWORD WINAPI ClickerThread(LPVOID lpParam) {
    srand((unsigned)time(NULL));
    while (true) {
        // Chờ signal hoặc stop
        HANDLE handles[2] = { hClickEvent, hStopEvent };
        DWORD waitResult = WaitForMultipleObjects(2, handles, FALSE, INFINITE);
        if (waitResult == WAIT_OBJECT_0 + 1) break; // Stop event -> thoát

        // Bắt đầu click loop
        while (isClicking) {
            // Xác định vị trí click
            int cx = 0, cy = 0;
            if (useFixedPos) {
                cx = fixedX;
                cy = fixedY;
            }

            switch (clickType) {
            case 0: // Left Click
                if (useFixedPos) {
                    SetCursorPos(cx, cy);
                    Sleep(5);
                }
                mouse_event(MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0);
                mouse_event(MOUSEEVENTF_LEFTUP,   0, 0, 0, 0);
                break;
            case 1: // Right Click
                if (useFixedPos) {
                    SetCursorPos(cx, cy);
                    Sleep(5);
                }
                mouse_event(MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, 0);
                mouse_event(MOUSEEVENTF_RIGHTUP,   0, 0, 0, 0);
                break;
            case 2: // Double Click
                if (useFixedPos) {
                    SetCursorPos(cx, cy);
                    Sleep(5);
                }
                mouse_event(MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0);
                mouse_event(MOUSEEVENTF_LEFTUP,   0, 0, 0, 0);
                Sleep(30);
                mouse_event(MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0);
                mouse_event(MOUSEEVENTF_LEFTUP,   0, 0, 0, 0);
                break;
            }

            InterlockedIncrement(&totalClicks);
            InterlockedIncrement(&clicksInSecond);

            // Kiểm tra giới hạn click
            if (useMaxClick && maxClicks > 0 && totalClicks >= maxClicks) {
                isClicking = false;
                ResetEvent(hClickEvent);
                PostMessage(g_hwnd, WM_COMMAND, MAKEWPARAM(ID_BUTTON_START, BN_CLICKED), 0);
                break;
            }

            // Sleep với variance
            int sleepTime = interval;
            if (useRandomVar && randomVariance > 0)
                sleepTime = RandRange(
                    max(1, interval - randomVariance),
                    interval + randomVariance
                );
            Sleep(sleepTime);
        }
    }
    return 0;
}

// ============================================================
//   CẬP NHẬT HIỂN THỊ TÊN PHÍM
// ============================================================
void UpdateKeyDisplay(int vkCode) {
    char keyName[32] = {};
    unsigned int sc = MapVirtualKey(vkCode, MAPVK_VK_TO_VSC);
    switch (vkCode) {
    case VK_LEFT:  strcpy_s(keyName, "Left");  break;
    case VK_RIGHT: strcpy_s(keyName, "Right"); break;
    case VK_UP:    strcpy_s(keyName, "Up");    break;
    case VK_DOWN:  strcpy_s(keyName, "Down");  break;
    default:       GetKeyNameTextA(sc << 16, keyName, sizeof(keyName));
    }
    if (!strlen(keyName)) strcpy_s(keyName, "Unknown");

    char buf[64];
    sprintf_s(buf, "Phim: [ %s ]", keyName);
    SetWindowTextA(hButtonSetKey, buf);

    sprintf_s(buf, "  BAT / TAT  ( %s )", keyName);
    SetWindowTextA(hButtonStart, buf);
}

// ============================================================
//   CẬP NHẬT THỐNG KÊ (mỗi 500ms)
// ============================================================
void UpdateStats() {
    // Tính CPS từ click trong 1 giây (timer gọi 2 lần/giây)
    LONG snap = InterlockedExchange(&clicksInSecond, 0);
    currentCPS = snap * 2.0f; // vì timer 500ms -> x2

    char buf[128];
    sprintf_s(buf,
        "Tong clicks: %ld  |  CPS: %.1f  |  Trang thai: %s",
        totalClicks, currentCPS,
        isClicking ? ">> DANG CHAY <<" : "DA TAT"
    );
    SetWindowTextA(hLabelStats, buf);
    SetWindowTextA(hStatus, isClicking ? ">> DANG CHAY <<" : "DA TAT");
}

// ============================================================
//   TẠO TRAY ICON
// ============================================================
void AddTrayIcon(HWND hwnd) {
    nid.cbSize           = sizeof(NOTIFYICONDATA);
    nid.hWnd             = hwnd;
    nid.uID              = ID_TRAY_ICON;
    nid.uFlags           = NIF_ICON | NIF_MESSAGE | NIF_TIP;
    nid.uCallbackMessage = WM_TRAYICON;
    nid.hIcon            = LoadIcon(GetModuleHandle(NULL), MAKEINTRESOURCE(IDI_ICON1));
    if (!nid.hIcon) nid.hIcon = LoadIcon(NULL, IDI_APPLICATION);
    strcpy_s(nid.szTip, "HVK Auto Clicker");
    Shell_NotifyIcon(NIM_ADD, &nid);
}
void RemoveTrayIcon() { Shell_NotifyIcon(NIM_DELETE, &nid); }

// ============================================================
//   VẼ NÚT TÙYCHỈNH (OWNERDRAW)
// ============================================================
void DrawCustomButton(LPDRAWITEMSTRUCT pDIS) {
    HDC hdc   = pDIS->hDC;
    RECT rect = pDIS->rcItem;
    bool pressed = (pDIS->itemState & ODS_SELECTED) != 0;

    COLORREF bgColor;
    bool isStart = (pDIS->CtlID == ID_BUTTON_START);
    if (isStart)
        bgColor = isClicking
            ? (pressed ? RGB(200,50,40) : COLOR_DANGER)
            : (pressed ? RGB(0,100,200) : COLOR_ACCENT);
    else
        bgColor = pressed ? COLOR_SURFACE2 : COLOR_SURFACE;

    // Vẽ nền
    HBRUSH hBr = CreateSolidBrush(bgColor);
    FillRect(hdc, &rect, hBr);
    DeleteObject(hBr);

    // Vẽ viền bo góc (giả lập bằng cách vẽ nhiều pixel)
    HBRUSH hBrBorder = CreateSolidBrush(COLOR_BORDER);
    FrameRect(hdc, &rect, hBrBorder);
    DeleteObject(hBrBorder);

    // Vẽ chữ
    char buf[64];
    GetWindowTextA(pDIS->hwndItem, buf, 64);
    SetBkMode(hdc, TRANSPARENT);
    SetTextColor(hdc, COLOR_TEXT);
    HFONT hFont = (HFONT)SendMessage(pDIS->hwndItem, WM_GETFONT, 0, 0);
    HFONT oldFont = (HFONT)SelectObject(hdc, hFont);
    DrawTextA(hdc, buf, -1, &rect, DT_CENTER | DT_VCENTER | DT_SINGLELINE);
    SelectObject(hdc, oldFont);
}

